# Base URL of the FastAPI agent service (dev default port is 8081).
VITE_AGENT_URL=http://localhost:8081

# Optional bearer token for the browser client.
#
# The FastAPI service enables bearer auth whenever AUTH_SECRET is set (the
# repo-root .env sets it, so a default `uv run python src/run_service.py`
# WILL require a token). Pick ONE of these for local dev:
#
#   (a) RECOMMENDED — start the service with auth disabled, leave this unset:
#         AUTH_SECRET= PORT=8081 uv run python src/run_service.py
#
#   (b) Keep auth on and mirror the secret here so the browser sends
#       `Authorization: Bearer <token>`:
#         VITE_AGENT_TOKEN=<same value as the service's AUTH_SECRET>
#
# Note: CORS is handled server-side (CORSMiddleware, origins configurable via
# CORS_ALLOW_ORIGINS); this dev origin (http://localhost:5173) is allowed by
# default, so no CORS config is needed for a standard `npm run dev`.
# VITE_AGENT_TOKEN=
