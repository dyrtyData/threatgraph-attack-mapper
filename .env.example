# =========================================================
# PF-001 Threat-Graph Mapper — environment template
# Copy to `.env` (git-ignored) and fill with real values.
# NEVER commit real keys. This file holds placeholders only.
# =========================================================

# ---------------------------------------------------------
# 1. FOUNDATION MODEL (choose one or both)
# ---------------------------------------------------------
OPENAI_API_KEY="sk-proj-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# ---------------------------------------------------------
# 2. LANGFUSE OBSERVABILITY (US region)
# ---------------------------------------------------------
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_HOST="https://us.cloud.langfuse.com"       # Langfuse Python SDK reads LANGFUSE_HOST
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"   # alias some tools expect

# ---------------------------------------------------------
# 3. MEM0 TEMPORAL MEMORY (hosted platform)
# ---------------------------------------------------------
MEM0_API_KEY="m0-..."

# ---------------------------------------------------------
# 4. AGENT-SERVICE-TOOLKIT (FastAPI / Streamlit auth)
# ---------------------------------------------------------
# Dummy string is fine for local prototyping.
AUTH_SECRET="local-development-secret-key"

# ---------------------------------------------------------
# 5. EVALUATION (optional)
# ---------------------------------------------------------
# DeepEval / Confident AI — SDK reads CONFIDENT_API_KEY (not CONFIDENTAI_*)
CONFIDENT_API_KEY="confident_..."
# Guardrails AI Hub token is NOT needed here — the CLI stores it in ~/.guardrailsrc
# after `guardrails configure`. Left out on purpose.

# ---------------------------------------------------------
# 6. RETRIEVAL / HYBRID RAG (optional)
# ---------------------------------------------------------
# Only needed if you use Cohere for embeddings and/or the rerank step.
# The full hybrid pipeline also works with OpenAI embeddings + a LOCAL
# sentence-transformers cross-encoder (no extra key). Leave blank to skip Cohere.
# COHERE_API_KEY="..."
